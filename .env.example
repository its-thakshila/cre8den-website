# Google Sheets / Google Forms integration
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit it.

# ── Testimonials (Google Sheet published as CSV) ──────────────────────────────
# Steps:
#   1. In your feedback Google Sheet, add a column called "Approved"
#   2. Type "Yes" for any review you want shown publicly
#   3. File → Share → Publish to web → Sheet1 → CSV → Publish
#   4. Paste the generated URL below
VITE_SHEET_CSV_URL=YOUR_PUBLISHED_SHEET_CSV_URL

# ── Newsletter subscription (Google Form) ────────────────────────────────────
# Steps:
#   1. Create a Google Form with a single "Email" field
#   2. Submit it once manually, then inspect the form source to find the entry ID
#      (search for "entry." in the page source)
#   3. Replace the values below
VITE_EMAIL_FORM_ID=YOUR_EMAIL_GOOGLE_FORM_ID
VITE_EMAIL_ENTRY_ID=entry.000000001

# ── Customer feedback (Google Form) ──────────────────────────────────────────
# Steps:
#   1. Create a Google Form with fields: Name, Rating, Message
#   2. Find each field's entry ID by inspecting the form source
VITE_FEEDBACK_FORM_ID=YOUR_FEEDBACK_GOOGLE_FORM_ID
VITE_FEEDBACK_ENTRY_NAME=entry.000000001
VITE_FEEDBACK_ENTRY_RATING=entry.000000002
VITE_FEEDBACK_ENTRY_MESSAGE=entry.000000003
